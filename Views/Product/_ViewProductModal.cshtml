@model E_Commerce_Product_Catalog.Models.Product

<div class="modal fade show" style="display:block;" id="viewModal">
    <div class="modal-dialog modal-xl">
        <div class="modal-content">

            <div class="modal-header">
                <h5 class="modal-title">View Details</h5>
                <button class="btn-close" onclick="closeModal()"></button>
            </div>

            <div class="modal-body">

                <div class="text-center mb-3">
                    <img id="mainProductImg" src="@Model.Images.FirstOrDefault()?.ImageUrl"
                         class="img-fluid rounded"
                         style="width:350px;" />
                </div>

                <div class="d-flex justify-content-center gap-2 mb-4" id="thumbList">
                    @foreach (var img in Model.Images)
                    {
                        <img src="@img.ImageUrl"
                             class="border rounded product-thumb" data-url="@img.ImageUrl"
                             style="width:70px;cursor:pointer;opacity:0.7;border:2px solid transparent;" />
                    }
                </div>

                <h3 class="fw-bold">@Model.Name</h3>

                <p class="mb-1">
                    SKU: <span class="fw-semibold text-primary">@Model.SKU</span>
                </p>
                <p class="mb-1">
                    Stock: <span class="fw-semibold">@Model.Stock</span>
                </p>
                <p class="mb-1">
                    Category: <span class="fw-semibold">@Model.CategoryId</span>
                </p>

                <h4 class="fw-bold text-primary mt-3">$@Model.Price</h4>

            </div>

        </div>
    </div>
</div>

<script>
    (function () {
        const main = document.getElementById('mainProductImg');
        const thumbs = document.querySelectorAll('.product-thumb');
        if (!thumbs || thumbs.length ===0) return;

        function setActive(el) {
            thumbs.forEach(t => {
                t.style.opacity = '0.7';
                t.style.borderColor = 'transparent';
            });
            el.style.opacity = '1';
            el.style.borderColor = '#0d6efd';
        }

        thumbs.forEach((t, idx) => {
            t.addEventListener('click', function () {
                const url = this.getAttribute('data-url');
                if (url) main.src = url;
                setActive(this);
            });
        });

        // set first as active
        const first = thumbs[0];
        if (first) setActive(first);
    })();
</script>